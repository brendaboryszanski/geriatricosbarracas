---
interface Photo {
  id: number;
  title: string;
  image_url: string;
  residence: string;
  subcategory: string;
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;

// Fixed residence options
const residenceFilters = [
  { label: 'Todas', value: 'all' },
  { label: 'Le-Sa', value: 'Le-Sa' },
  { label: 'Rincón del Sur', value: 'Rincón del Sur' },
];

// Dynamic subcategory filters from DB
const rawSubcategories = [...new Set(photos.map(p => p.subcategory).filter(Boolean))];
const hasSubcategories = rawSubcategories.length > 1;

const PAGE_SIZE = 12;
---

<style>
  .gallery-placeholder {
    background: linear-gradient(135deg, #e8d8c8 0%, #f5e6d3 100%);
    transition: opacity 0.4s ease;
  }
  .gallery-placeholder.loaded { opacity: 0; }

  #gallery-grid { column-gap: 12px; }
  .gallery-item {
    break-inside: avoid;
    margin-bottom: 12px;
    transition: opacity 0.3s ease;
  }
  .gallery-item.hidden { display: none; }
  .gallery-item img { transition: transform 0.5s ease; display: block; }
  .gallery-item:hover img { transform: scale(1.04); }
  .gallery-item .overlay { opacity: 0; transition: opacity 0.3s ease; }
  .gallery-item:hover .overlay { opacity: 1; }

  .filter-btn { transition: all 0.2s ease; }
  .filter-btn.active { background-color: var(--color-sage); color: white; border-color: var(--color-sage); }
</style>

<section id="fotos" class="bg-blush py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-10 reveal">
      <h2 class="font-heading font-800 text-3xl md:text-4xl text-sage mb-3">Mirá las residencias desde adentro</h2>
      <p class="text-warm-gray text-lg max-w-xl mx-auto">Espacios cálidos pensados para sentirse en casa.</p>
    </div>

    <!-- Filters -->
    <div class="flex flex-col items-center gap-3 mb-8">
      <!-- Residence -->
      <div class="flex flex-wrap justify-center gap-2">
        {residenceFilters.map((f) => (
          <button
            data-residence={f.value}
            class={`filter-btn residence-filter px-5 py-2 rounded-full text-sm font-medium border transition-all ${f.value === 'all' ? 'active bg-sage text-white border-sage' : 'bg-white text-warm-gray border-warm-border hover:border-sage hover:text-sage'}`}
          >
            {f.label}
          </button>
        ))}
      </div>

      <!-- Subcategory — smaller pills, only if more than 1 -->
      {hasSubcategories && (
        <div class="flex flex-wrap justify-center gap-2">
          <button data-sub="all" class="filter-btn sub-filter active px-3 py-1 rounded-full text-xs font-medium border bg-warm-dark text-white border-warm-dark transition-all">
            Todos los ambientes
          </button>
          {rawSubcategories.map((s) => (
            <button
              data-sub={s}
              class="filter-btn sub-filter px-3 py-1 rounded-full text-xs font-medium border bg-white text-warm-gray border-warm-border hover:border-warm-dark hover:text-warm-dark transition-all"
            >
              {s}
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- Masonry grid -->
    <div id="gallery-grid" class="columns-2 sm:columns-3 lg:columns-4">
      {photos.map((p, i) => (
        <div
          class="gallery-item relative overflow-hidden rounded-xl cursor-pointer"
          data-residence={p.residence}
          data-sub={p.subcategory}
          data-index={i}
        >
          <div class="relative">
            <div class="gallery-placeholder absolute inset-0 rounded-xl"></div>
            <img
              src={p.image_url}
              data-full={p.image_url}
              data-title={p.title}
              alt={p.title}
              loading="lazy"
              class="gallery-img w-full object-cover rounded-xl"
              onload="this.previousElementSibling.classList.add('loaded')"
            />
            <div class="overlay absolute inset-0 bg-warm-dark/40 rounded-xl flex items-end">
              <p class="text-white text-xs font-medium px-3 pb-2">{p.title}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Pagination -->
    <div id="gallery-pagination" class="flex items-center justify-center gap-3 mt-8">
      <button id="gallery-prev" disabled
        class="flex items-center gap-1.5 px-4 py-2 rounded-full border border-warm-border text-warm-gray text-sm font-medium transition-all disabled:opacity-30 disabled:cursor-not-allowed hover:not-disabled:border-sage hover:not-disabled:text-sage">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Anterior
      </button>
      <span id="gallery-page-info" class="text-warm-gray text-sm"></span>
      <button id="gallery-next"
        class="flex items-center gap-1.5 px-4 py-2 rounded-full border border-warm-border text-warm-gray text-sm font-medium transition-all disabled:opacity-30 disabled:cursor-not-allowed hover:not-disabled:border-sage hover:not-disabled:text-sage">
        Siguiente
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-50 bg-black/92 hidden items-center justify-center p-4" role="dialog" aria-modal="true">
  <button id="lightbox-close" class="absolute top-4 right-4 text-white/60 hover:text-white transition-colors" aria-label="Cerrar">
    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
  <button id="lightbox-prev" class="absolute left-3 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors p-2" aria-label="Anterior">
    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <button id="lightbox-next" class="absolute right-3 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors p-2" aria-label="Siguiente">
    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </button>
  <div class="flex flex-col items-center gap-3 max-w-4xl w-full">
    <img id="lightbox-img" src="" alt="" class="max-h-[82vh] max-w-full rounded-xl object-contain shadow-2xl" />
    <p id="lightbox-title" class="text-white/70 text-sm"></p>
  </div>
</div>

<script is:inline>
  const PAGE_SIZE = 12;
  let currentPage = 1;
  let activeResidence = 'all';
  let activeSub = 'all';
  let lbIndex = 0;

  function allItems() {
    return Array.from(document.querySelectorAll('.gallery-item'));
  }

  function filteredItems() {
    return allItems().filter(item => {
      const res = item.getAttribute('data-residence') || 'Ambas';
      const sub = item.getAttribute('data-sub') || 'Otros';
      const resMatch = activeResidence === 'all' || res === activeResidence || res === 'Ambas';
      const subMatch = activeSub === 'all' || sub === activeSub;
      return resMatch && subMatch;
    });
  }

  function setActiveBtn(selector, activeVal) {
    const isResidence = selector.includes('residence');
    document.querySelectorAll(selector).forEach(b => {
      const val = b.getAttribute(isResidence ? 'data-residence' : 'data-sub');
      const isActive = val === activeVal;
      b.classList.toggle('active', isActive);
      if (isResidence) {
        b.classList.toggle('bg-sage', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('border-sage', isActive);
        b.classList.toggle('bg-white', !isActive);
        b.classList.toggle('text-warm-gray', !isActive);
        b.classList.toggle('border-warm-border', !isActive);
      } else {
        b.classList.toggle('bg-warm-dark', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('border-warm-dark', isActive);
        b.classList.toggle('bg-white', !isActive);
        b.classList.toggle('text-warm-gray', !isActive);
        b.classList.toggle('border-warm-border', !isActive);
      }
    });
  }

  function renderPage() {
    const items = filteredItems();
    const total = items.length;
    const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    currentPage = Math.min(currentPage, totalPages);
    const start = (currentPage - 1) * PAGE_SIZE;
    const end = start + PAGE_SIZE;

    allItems().forEach(item => item.classList.add('hidden'));
    items.forEach((item, i) => {
      item.classList.toggle('hidden', i < start || i >= end);
    });

    const info = document.getElementById('gallery-page-info');
    const prev = document.getElementById('gallery-prev');
    const next = document.getElementById('gallery-next');
    const pagination = document.getElementById('gallery-pagination');

    if (info) info.textContent = totalPages > 1 ? `${currentPage} / ${totalPages}` : '';
    if (prev) prev.disabled = currentPage <= 1;
    if (next) next.disabled = currentPage >= totalPages;
    if (pagination) pagination.style.display = totalPages <= 1 ? 'none' : '';
  }

  // Residence filter
  document.querySelectorAll('.residence-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      activeResidence = btn.getAttribute('data-residence');
      currentPage = 1;
      setActiveBtn('.residence-filter', activeResidence);
      renderPage();
    });
  });

  // Subcategory filter
  document.querySelectorAll('.sub-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      activeSub = btn.getAttribute('data-sub');
      currentPage = 1;
      setActiveBtn('.sub-filter', activeSub);
      renderPage();
    });
  });

  // Pagination
  document.getElementById('gallery-prev')?.addEventListener('click', () => {
    if (currentPage > 1) { currentPage--; renderPage(); window.scrollTo({ top: document.getElementById('fotos').offsetTop - 80, behavior: 'smooth' }); }
  });
  document.getElementById('gallery-next')?.addEventListener('click', () => {
    const total = Math.ceil(filteredItems().length / PAGE_SIZE);
    if (currentPage < total) { currentPage++; renderPage(); window.scrollTo({ top: document.getElementById('fotos').offsetTop - 80, behavior: 'smooth' }); }
  });

  renderPage();

  // Fix: images already loaded from cache won't fire onload
  document.querySelectorAll('.gallery-img').forEach(img => {
    if (img.complete) img.previousElementSibling?.classList.add('loaded');
  });

  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');
  const lbTitle = document.getElementById('lightbox-title');

  function visibleImgs() {
    return Array.from(document.querySelectorAll('.gallery-item:not(.hidden) .gallery-img'));
  }

  function openLightbox(img) {
    lbIndex = visibleImgs().indexOf(img);
    lbImg.src = img.getAttribute('data-full') || img.src;
    lbImg.alt = img.alt;
    lbTitle.textContent = img.getAttribute('data-title') || '';
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function navigate(dir) {
    const imgs = visibleImgs();
    lbIndex = (lbIndex + dir + imgs.length) % imgs.length;
    const img = imgs[lbIndex];
    lbImg.src = img.getAttribute('data-full') || img.src;
    lbImg.alt = img.alt;
    lbTitle.textContent = img.getAttribute('data-title') || '';
  }

  document.querySelectorAll('.gallery-item').forEach(item => {
    item.addEventListener('click', () => {
      const img = item.querySelector('.gallery-img');
      if (img) openLightbox(img);
    });
  });

  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev').addEventListener('click', () => navigate(-1));
  document.getElementById('lightbox-next').addEventListener('click', () => navigate(1));
  lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', e => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  });
</script>
