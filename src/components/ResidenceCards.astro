---
interface Residence {
  name: string;
  address: string;
  phone: string;
  description: string;
  amenities: string[];
}

interface Props {
  residences: Residence[];
}

const { residences } = Astro.props;
---

<section id="residencias" class="bg-cream py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="font-heading font-800 text-3xl md:text-4xl text-sage mb-3">Nuestras Residencias</h2>
      <p class="text-warm-gray text-lg max-w-xl mx-auto">Dos hogares con atención personalizada, atendidos directamente por sus dueños.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {residences.map((r) => (
        <div class="bg-white rounded-2xl shadow-sm border border-warm-border overflow-hidden hover:shadow-md transition-shadow">
          <div class="bg-sage p-6">
            <h3 class="font-heading font-700 text-2xl text-white">{r.name}</h3>
            <p class="text-white/80 text-sm mt-1">📍 {r.address}</p>
            {r.phone && <p class="text-white/80 text-sm">📞 {r.phone}</p>}
          </div>
          <div class="p-6">
            <p class="text-warm-gray leading-relaxed mb-5">{r.description}</p>
            {r.amenities && r.amenities.length > 0 && (
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {r.amenities.map((item: string) => (
                  <li class="flex items-start gap-2 text-sm text-warm-dark">
                    <span class="text-terracotta mt-0.5 shrink-0">✓</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
