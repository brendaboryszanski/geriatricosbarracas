---
interface Objective {
  target: string;
  title: string;
  description: string;
}

interface Props {
  objectives: Objective[];
}

const { objectives } = Astro.props;

const icons: Record<string, string> = {
  residentes: '🏡',
  familiares: '👨‍👩‍👧',
};
---

<section id="objetivos" class="bg-sage py-20 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="font-heading font-800 text-3xl md:text-4xl text-white mb-3">Nuestros objetivos</h2>
      <p class="text-white/80 text-lg max-w-xl mx-auto">El bienestar de cada persona, en el centro de todo lo que hacemos.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {objectives.map((obj) => (
        <div class="bg-white/10 backdrop-blur rounded-2xl p-8 border border-white/20">
          <div class="text-4xl mb-4">{icons[obj.target] ?? '⭐'}</div>
          <h3 class="font-heading font-700 text-white text-xl mb-3">{obj.title}</h3>
          <p class="text-white/80 leading-relaxed">{obj.description}</p>
        </div>
      ))}
    </div>

    <p class="text-center text-white/70 mt-10 italic text-lg font-heading">
      "Y así poder crecer día a día..."
    </p>
  </div>
</section>
