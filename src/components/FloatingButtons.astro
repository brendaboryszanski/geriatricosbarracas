---
// Phone numbers for both residences
const whatsappLesa = '541143017992';
const whatsappRincon = '5491134478263';
---

<!-- WhatsApp menu -->
<div id="whatsapp-menu" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-2">

  <!-- Options (hidden by default) -->
  <div id="wa-options" class="hidden flex-col items-end gap-2 mb-1">
    <a
      href={`https://wa.me/${whatsappRincon}?text=Hola%2C%20quisiera%20consultar%20sobre%20Rinc%C3%B3n%20del%20Sur`}
      target="_blank" rel="noopener"
      class="flex items-center gap-2 bg-white text-warm-dark text-sm font-medium px-4 py-2 rounded-full shadow-md border border-warm-border hover:bg-green-50 transition-colors"
    >
      <span class="w-2 h-2 rounded-full bg-green-500 shrink-0"></span>
      Rincón del Sur
    </a>
    <a
      href={`https://wa.me/${whatsappLesa}?text=Hola%2C%20quisiera%20consultar%20sobre%20Le-Sa`}
      target="_blank" rel="noopener"
      class="flex items-center gap-2 bg-white text-warm-dark text-sm font-medium px-4 py-2 rounded-full shadow-md border border-warm-border hover:bg-green-50 transition-colors"
    >
      <span class="w-2 h-2 rounded-full bg-green-500 shrink-0"></span>
      Le-Sa
    </a>
  </div>

  <!-- Main WhatsApp button -->
  <button
    id="wa-toggle"
    aria-label="Contactar por WhatsApp"
    class="w-14 h-14 rounded-full shadow-lg flex items-center justify-center transition-transform hover:scale-110 active:scale-95"
    style="background-color: #25D366;"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="white" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </button>
</div>

<!-- Scroll to top -->
<button
  id="scroll-top"
  aria-label="Volver al inicio"
  class="fixed bottom-24 right-6 z-50 w-10 h-10 rounded-full shadow-md flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300"
  style="background-color: #5B7B6F;"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
  </svg>
</button>

<script is:inline>
  // WhatsApp toggle
  const waToggle = document.getElementById('wa-toggle');
  const waOptions = document.getElementById('wa-options');
  waToggle?.addEventListener('click', () => {
    const hidden = waOptions?.classList.contains('hidden');
    waOptions?.classList.toggle('hidden', !hidden);
    waOptions?.classList.toggle('flex', hidden);
  });
  document.addEventListener('click', (e) => {
    if (!document.getElementById('whatsapp-menu')?.contains(e.target)) {
      waOptions?.classList.add('hidden');
      waOptions?.classList.remove('flex');
    }
  });

  // Scroll to top
  const scrollBtn = document.getElementById('scroll-top');
  window.addEventListener('scroll', () => {
    const show = window.scrollY > 400;
    scrollBtn?.classList.toggle('opacity-0', !show);
    scrollBtn?.classList.toggle('pointer-events-none', !show);
    scrollBtn?.classList.toggle('opacity-100', show);
  });
  scrollBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>
