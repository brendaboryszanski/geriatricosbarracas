---
import { optimizeImage } from '../lib/utils';

interface Slide {
  image_url: string;
  caption: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
---

<style>
  .hero-swiper .swiper-slide img {
    transition: transform 6s ease;
    transform: scale(1.05);
  }
  .hero-swiper .swiper-slide-active img {
    transform: scale(1);
  }
  .slide-caption {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s ease 0.3s, transform 0.8s ease 0.3s;
  }
  .swiper-slide-active .slide-caption {
    opacity: 1;
    transform: translateY(0);
  }
  .swiper-button-next,
  .swiper-button-prev {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    width: 44px !important;
    height: 44px !important;
    transition: background 0.2s;
  }
  .swiper-button-next:hover,
  .swiper-button-prev:hover {
    background: rgba(255,255,255,0.3);
  }
  .swiper-button-next::after,
  .swiper-button-prev::after {
    font-size: 16px !important;
    font-weight: 700;
    color: white;
  }
  #slide-progress-bars {
    gap: 3px;
    padding: 0 4px 4px;
  }
</style>

<section id="home" class="relative pt-14">
  <div class="swiper hero-swiper h-[80vh] min-h-[480px]">
    <div class="swiper-wrapper">
      {slides.map((slide, i) => (
        <div class="swiper-slide relative overflow-hidden">
          <img
            src={optimizeImage(slide.image_url, 1920, 75)}
            alt={slide.caption}
            class="w-full h-full object-cover"
            loading={i === 0 ? 'eager' : 'lazy'}
            fetchpriority={i === 0 ? 'high' : 'auto'}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-black/10 flex items-end">
            <div class="max-w-6xl mx-auto px-6 pb-20 w-full">
              <p class="slide-caption text-white text-2xl md:text-4xl font-heading font-700 max-w-2xl leading-tight drop-shadow-lg">
                {slide.caption}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="swiper-button-prev" style="left: 20px;"></div>
    <div class="swiper-button-next" style="right: 20px;"></div>
  </div>

  <!-- Progress bar pagination -->
  <div id="slide-progress-bars" class="absolute bottom-0 left-0 right-0 flex z-20"></div>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" is:inline></script>
<script is:inline>
  const DELAY = 4000;
  const SPEED = 800;
  const totalSlides = document.querySelectorAll('.hero-swiper .swiper-slide').length;

  // Build progress bars
  const container = document.getElementById('slide-progress-bars');
  const bars = [];
  for (let i = 0; i < totalSlides; i++) {
    const wrap = document.createElement('div');
    wrap.className = 'flex-1 h-1 bg-white/25 cursor-pointer';
    wrap.addEventListener('click', () => swiper.slideToLoop(i));
    const fill = document.createElement('div');
    fill.className = 'h-full bg-white/80 w-0';
    fill.style.transition = 'none';
    wrap.appendChild(fill);
    container.appendChild(wrap);
    bars.push(fill);
  }

  let animFrame;

  function startBar(index) {
    bars.forEach((b, i) => {
      b.style.transition = 'none';
      b.style.width = i < index ? '100%' : '0%';
    });
    const bar = bars[index];
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        bar.style.transition = `width ${DELAY}ms linear`;
        bar.style.width = '100%';
      });
    });
  }

  const swiper = new Swiper('.hero-swiper', {
    loop: true,
    speed: SPEED,
    autoplay: { delay: DELAY, disableOnInteraction: false, pauseOnMouseEnter: false },
    effect: 'fade',
    fadeEffect: { crossFade: true },
    navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
    on: {
      slideChange() {
        startBar(this.realIndex);
      },
    }
  });

  startBar(0);
</script>
