---
interface ContactData {
  email: string;
  map_url: string;
  residences: Array<{ name: string; phone: string; address: string }>;
}

interface Props {
  contact: ContactData;
}

const { contact } = Astro.props;
---

<section id="contacto" class="bg-blush py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="font-heading font-800 text-3xl md:text-4xl text-sage mb-3">Contacto</h2>
      <p class="text-warm-gray text-lg max-w-xl mx-auto">No dudes en consultar tus inquietudes.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-10 mb-10">
      <!-- Contact info -->
      <div class="flex flex-col gap-6">
        {contact.residences?.map((r) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-warm-border">
            <h3 class="font-heading font-700 text-sage text-lg mb-3">{r.name}</h3>
            <div class="flex flex-col gap-2 text-sm text-warm-gray">
              <p>📞 <span class="text-warm-dark">{r.phone}</span></p>
              <p>📍 <span class="text-warm-dark">{r.address}</span></p>
            </div>
          </div>
        ))}

        <div class="bg-white rounded-2xl p-6 shadow-sm border border-warm-border">
          <h3 class="font-heading font-700 text-sage text-lg mb-3">Email</h3>
          <a href={`mailto:${contact.email}`} class="text-terracotta hover:underline text-sm">{contact.email}</a>

          <div class="flex flex-col gap-2 mt-4">
            <a href="https://www.google.com/maps/place/?q=place_id:ChIJeUHXc1DLvJURowRnVXIBMf0" target="_blank" rel="noopener"
               class="flex items-center gap-2 text-sage hover:text-sage-dark text-sm font-medium transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              Reseñas de Le-Sa en Google
            </a>
            <a href="https://www.google.com/maps/place/?q=place_id:ChIJ7emZFlPLvJURHUDH-GLvdjM" target="_blank" rel="noopener"
               class="flex items-center gap-2 text-sage hover:text-sage-dark text-sm font-medium transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              Reseñas de Rincón del Sur en Google
            </a>
          </div>

          <p class="mt-5 text-xs text-warm-gray italic">Dr. Julio Boryszanski y Lic. Marcela Yudewitz</p>
        </div>
      </div>

      <!-- Map -->
      <div class="rounded-2xl overflow-hidden shadow-sm border border-warm-border">
        <iframe
          src={contact.map_url}
          width="100%"
          height="100%"
          style="min-height: 360px; border: 0;"
          allowfullscreen
          loading="lazy"
          title="Ubicación de las residencias"
        />
      </div>
    </div>
  </div>
</section>
