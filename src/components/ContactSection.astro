---
interface ContactData {
  email: string;
  map_url: string;
  residences: Array<{ name: string; phone: string; address: string }>;
}

interface Props {
  contact: ContactData;
}

const { contact } = Astro.props;

function cleanPhone(phone: string) {
  return phone.replace(/\s|-/g, '').replace(/^\+/, '+');
}

const web3formsKey = import.meta.env.WEB3FORMS_ACCESS_KEY ?? '';
---

<section id="contacto" class="bg-blush py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="font-heading font-800 text-3xl md:text-4xl text-sage mb-3">Contacto</h2>
      <p class="text-warm-gray text-lg max-w-xl mx-auto">No dudes en consultar tus inquietudes.</p>
    </div>

    <div class="grid md:grid-cols-5 gap-8 mb-10 items-stretch">
      <!-- Izquierda: card combinada de residencias -->
      <div class="md:col-span-2 bg-white rounded-2xl p-6 md:p-8 shadow-sm border border-warm-border flex flex-col">
        <h3 class="font-heading font-700 text-sage text-xl mb-5 text-center">Nuestras residencias</h3>
        <div class="flex flex-col gap-5">
          {contact.residences?.map((r, i) => (
            <div class={i > 0 ? 'pt-5 border-t border-warm-border' : ''}>
              <h4 class="font-heading font-700 text-sage text-lg mb-2">{r.name}</h4>
              <div class="flex flex-col gap-2 text-sm text-warm-gray">
                <p class="flex items-center gap-2">
                  <span>📞</span>
                  <a
                    href={`tel:${cleanPhone(r.phone)}`}
                    class="text-warm-dark md:pointer-events-none md:cursor-default"
                  >
                    {r.phone}
                  </a>
                </p>
                <p class="flex items-start gap-2">
                  <span>📍</span>
                  <span class="text-warm-dark">{r.address}</span>
                </p>
              </div>
              <a
                href={`tel:${cleanPhone(r.phone)}`}
                class="mt-3 flex md:hidden items-center justify-center gap-2 bg-sage hover:bg-sage-dark text-white rounded-xl px-4 py-2 text-sm font-medium transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                Llamar
              </a>
            </div>
          ))}
        </div>
        <div class="mt-auto pt-6 border-t border-warm-border/60 text-center">
          <p class="text-xs text-warm-gray italic">Atendido personalmente por sus dueños</p>
          <p class="text-sm font-heading font-700 text-sage mt-1">Dr. Julio Boryszanski</p>
          <p class="text-sm font-heading font-700 text-sage">Lic. Marcela Yudewitz</p>
        </div>
      </div>

      <!-- Derecha: Formulario de consulta -->
      <div class="md:col-span-3 bg-white rounded-2xl p-6 md:p-8 shadow-sm border border-warm-border">
        <h3 class="font-heading font-700 text-sage text-xl mb-2 text-center">Enviá tu consulta</h3>
        <p class="text-warm-gray text-sm text-center mb-2">Te respondemos a la brevedad.</p>
        <p class="text-warm-gray text-sm text-center mb-6">
          O escribinos directamente a
          <a href={`mailto:${contact.email}`} class="text-terracotta hover:underline">{contact.email}</a>
        </p>

        <form id="contact-form" class="flex flex-col gap-4">
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="Consulta desde geriatricosbarracas.com.ar" />
          <input type="hidden" name="from_name" value="Web geriatricosbarracas" />
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

          <div>
            <label for="cf-name" class="block text-sm font-medium text-warm-dark mb-1">Nombre *</label>
            <input id="cf-name" type="text" name="name" required autocomplete="name"
              class="w-full rounded-xl border border-warm-border px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sage/40" />
          </div>

          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label for="cf-email" class="block text-sm font-medium text-warm-dark mb-1">Email *</label>
              <input id="cf-email" type="email" name="email" required autocomplete="email"
                class="w-full rounded-xl border border-warm-border px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sage/40" />
            </div>
            <div>
              <label for="cf-phone" class="block text-sm font-medium text-warm-dark mb-1">Teléfono *</label>
              <input id="cf-phone" type="tel" name="phone" required autocomplete="tel"
                class="w-full rounded-xl border border-warm-border px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sage/40" />
            </div>
          </div>

          <div>
            <label for="cf-msg" class="block text-sm font-medium text-warm-dark mb-1">Mensaje *</label>
            <textarea id="cf-msg" name="message" rows="4" required
              class="w-full rounded-xl border border-warm-border px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sage/40"></textarea>
          </div>

          <button type="submit" id="contact-submit"
            class="bg-sage hover:bg-sage-dark text-white font-medium rounded-xl px-6 py-3 transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
            Enviar consulta
          </button>

          <p id="contact-status" class="text-sm text-center hidden"></p>
        </form>
      </div>
    </div>

    <!-- Mapa abajo, full-width landscape -->
    <div class="rounded-2xl overflow-hidden shadow-sm border border-warm-border">
      <iframe
        src={contact.map_url}
        class="w-full block"
        style="border: 0; height: 420px;"
        allowfullscreen
        loading="lazy"
        title="Ubicación de las residencias"
      />
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-status') as HTMLParagraphElement | null;
  const btn = document.getElementById('contact-submit') as HTMLButtonElement | null;

  function setStatus(msg: string, kind: 'info' | 'ok' | 'error') {
    if (!status) return;
    status.textContent = msg;
    status.classList.remove('hidden', 'text-sage', 'text-terracotta', 'text-warm-gray');
    status.classList.add(kind === 'ok' ? 'text-sage' : kind === 'error' ? 'text-terracotta' : 'text-warm-gray');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !btn) return;

    const data = new FormData(form);
    const payload: Record<string, any> = {};
    data.forEach((v, k) => { payload[k] = v; });

    btn.disabled = true;
    setStatus('Enviando…', 'info');

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(payload),
      });
      const json = await res.json().catch(() => ({}));
      if (res.ok && json.success) {
        setStatus('¡Mensaje enviado! Te respondemos a la brevedad.', 'ok');
        form.reset();
      } else {
        setStatus('Error al enviar. Probá de nuevo o escribinos a info@geriatricosbarracas.com.ar', 'error');
      }
    } catch {
      setStatus('Error de conexión. Probá de nuevo o escribinos a info@geriatricosbarracas.com.ar', 'error');
    } finally {
      btn.disabled = false;
    }
  });
</script>
