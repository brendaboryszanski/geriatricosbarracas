---
interface Props {
  text?: string;
}
const { text = 'Residencias para adultos mayores' } = Astro.props;
---

<footer class="bg-warm-dark py-8 px-4 text-center">
  <p class="text-white/60 text-sm">{text}</p>
  <p class="text-white/30 text-xs mt-2">© {new Date().getFullYear()} Geriátricos Barracas · Le-Sa y Rincón del Sur</p>
</footer>
