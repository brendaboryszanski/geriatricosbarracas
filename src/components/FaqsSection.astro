---
interface Faq {
  id: number;
  question: string;
  answer: string;
  order: number;
}

interface Props {
  faqs: Faq[];
}

const { faqs } = Astro.props;

if (faqs.length === 0) return;
---

<section id="faqs" class="bg-cream py-20 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="font-heading font-800 text-3xl md:text-4xl text-sage mb-3">Preguntas frecuentes</h2>
      <p class="text-warm-gray text-lg">Respondemos las consultas más comunes de las familias.</p>
    </div>

    <div class="flex flex-col gap-3">
      {faqs.map((faq, i) => (
        <div class="faq-item bg-white rounded-2xl border border-warm-border overflow-hidden">
          <button
            type="button"
            class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left font-heading font-700 text-warm-dark hover:text-sage transition-colors"
            aria-expanded="false"
          >
            <span>{faq.question}</span>
            <svg class="faq-icon shrink-0 w-5 h-5 text-sage transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-5 text-warm-gray text-sm leading-relaxed">
            {faq.answer}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item.querySelector('.faq-answer');
      const icon = btn.querySelector('.faq-icon');
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all others
      document.querySelectorAll('.faq-item').forEach(other => {
        if (other !== item) {
          other.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
          other.querySelector('.faq-answer').classList.add('hidden');
          other.querySelector('.faq-icon').style.transform = '';
        }
      });

      // Toggle current
      btn.setAttribute('aria-expanded', String(!isOpen));
      answer.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
    });
  });
</script>
