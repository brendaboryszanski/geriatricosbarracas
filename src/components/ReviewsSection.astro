---
import reviewsData from '../data/reviews.json';

const PLACES = reviewsData.places;
const reviews = reviewsData.reviews;

function relativeTimeEs(isoDate: string): string {
  const then = new Date(isoDate).getTime();
  const now = Date.now();
  const days = Math.max(0, Math.floor((now - then) / (1000 * 60 * 60 * 24)));
  if (days < 14) return 'Hace pocos días';
  if (days < 60) return `Hace ${Math.round(days / 7)} semanas`;
  const months = Math.round(days / 30);
  if (months < 12) return `Hace ${months} ${months === 1 ? 'mes' : 'meses'}`;
  const years = Math.round(days / 365);
  return `Hace ${years} ${years === 1 ? 'año' : 'años'}`;
}
---

{reviews.length > 0 && (
  <section id="resenas" class="bg-cream py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="font-heading font-800 text-3xl md:text-4xl text-sage mb-3">Lo que dicen las familias</h2>

        <!-- Rating summary -->
        <div class="flex flex-col items-center gap-2 mt-6 mb-6">
          <div class="text-yellow-400 text-2xl tracking-wider">★★★★★</div>
          <p class="text-warm-gray text-sm">Más de 50 familias compartieron su experiencia en Google</p>
        </div>

        <!-- Filter buttons -->
        <div class="flex flex-wrap justify-center gap-2">
          <button data-filter="all" class="review-filter px-5 py-2 rounded-full text-sm font-medium border bg-sage text-white border-sage transition-all">Todas</button>
          {PLACES.map(p => (
            <button data-filter={p.name} class="review-filter px-5 py-2 rounded-full text-sm font-medium border bg-white text-warm-gray border-warm-border hover:border-sage hover:text-sage transition-all">{p.name}</button>
          ))}
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {reviews.map((review) => (
          <div
            class="review-card bg-white rounded-2xl p-5 shadow-sm border border-warm-border flex flex-col gap-3"
            data-residence={review.residence}
          >
            <!-- Header -->
            <div class="flex items-center gap-3">
              <div class="review-avatar w-10 h-10 rounded-full bg-sage/20 flex items-center justify-center text-sage font-heading font-700 text-base shrink-0 overflow-hidden">
                {review.photoUri ? (
                  <img
                    src={review.photoUri}
                    alt={review.displayName}
                    class="w-full h-full object-cover"
                    referrerpolicy="no-referrer"
                    onerror="this.replaceWith(Object.assign(document.createElement('span'),{textContent:this.alt?.[0]??'?'}))"
                  />
                ) : (
                  <span>{review.displayName?.[0] ?? '?'}</span>
                )}
              </div>
              <div>
                <p class="font-medium text-warm-dark text-sm">{review.displayName}</p>
                <p class="text-warm-gray text-xs">{relativeTimeEs(review.publishTime)}</p>
              </div>
              <span class="ml-auto text-xs text-terracotta font-medium">{review.residence}</span>
            </div>

            <!-- Stars -->
            <div class="text-yellow-400 text-base leading-none">
              {'★'.repeat(review.rating)}{'☆'.repeat(5 - review.rating)}
            </div>

            <!-- Text with expand -->
            {review.text && (
              <div class="flex flex-col gap-2 flex-1">
                <p
                  class="review-text text-warm-gray text-sm leading-relaxed line-clamp-4"
                  data-full={review.text}
                >
                  "{review.text}"
                </p>
                <div class="flex items-center gap-3">
                  <button
                    class="review-expand text-sage text-xs font-medium hover:underline self-start"
                    data-expanded="false"
                  >
                    Ver más
                  </button>
                  <a
                    href={`https://www.google.com/maps/place/?q=place_id:${PLACES.find(p => p.name === review.residence)?.id}`}
                    target="_blank"
                    rel="noopener"
                    class="text-warm-gray text-xs hover:underline self-start"
                  >
                    Google Maps →
                  </a>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="text-center mt-8 flex justify-center gap-6">
        {PLACES.map(p => (
          <a
            href={`https://www.google.com/maps/place/?q=place_id:${p.id}`}
            target="_blank"
            rel="noopener"
            class="text-sage hover:text-sage-dark text-sm font-medium hover:underline transition-colors"
          >
            Ver todas las reseñas de {p.name} →
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<script is:inline>
  // Filter
  document.querySelectorAll('.review-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('.review-filter').forEach(b => {
        b.classList.remove('bg-sage', 'text-white', 'border-sage');
        b.classList.add('bg-white', 'text-warm-gray', 'border-warm-border');
      });
      btn.classList.add('bg-sage', 'text-white', 'border-sage');
      btn.classList.remove('bg-white', 'text-warm-gray', 'border-warm-border');
      document.querySelectorAll('.review-card').forEach(card => {
        const match = filter === 'all' || card.getAttribute('data-residence') === filter;
        card.style.display = match ? '' : 'none';
      });
    });
  });

  // Expand/collapse
  document.querySelectorAll('.review-expand').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = btn.closest('div').previousElementSibling;
      const expanded = btn.getAttribute('data-expanded') === 'true';
      if (expanded) {
        p.classList.add('line-clamp-4');
        btn.textContent = 'Ver más';
        btn.setAttribute('data-expanded', 'false');
      } else {
        p.classList.remove('line-clamp-4');
        btn.textContent = 'Ver menos';
        btn.setAttribute('data-expanded', 'true');
      }
    });
  });
</script>
