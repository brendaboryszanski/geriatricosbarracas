---
---
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background-color: #5B7B6F;">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <!-- Brand -->
    <a href="#home" class="flex flex-col leading-tight">
      <span class="font-heading font-800 text-white text-lg tracking-wide">Le-Sa · Rincón del Sur</span>
      <span class="text-white/80 text-xs font-light tracking-widest uppercase">Residencias para Adultos Mayores</span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-6 text-sm font-medium text-white/90">
      <li><a href="#home" class="hover:text-white transition-colors">Presentación</a></li>
      <li><a href="#servicios" class="hover:text-white transition-colors">Servicios</a></li>
      <li><a href="#fotos" class="hover:text-white transition-colors">Fotos</a></li>
      <li><a href="#equipo" class="hover:text-white transition-colors">Equipo</a></li>
      <li><a href="#resenas" class="hover:text-white transition-colors">Reseñas</a></li>
      <li><a href="#contacto" class="hover:text-white transition-colors">Contacto</a></li>
    </ul>

    <!-- Mobile hamburger -->
    <button id="menu-btn" aria-label="Abrir menú" class="md:hidden text-white p-1">
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/20">
    <ul class="flex flex-col px-4 pb-4 pt-2 gap-2 text-sm font-medium text-white/90">
      <li><a href="#home" class="block py-1 hover:text-white">Presentación</a></li>
      <li><a href="#servicios" class="block py-1 hover:text-white">Servicios</a></li>
      <li><a href="#fotos" class="block py-1 hover:text-white">Fotos</a></li>
      <li><a href="#equipo" class="block py-1 hover:text-white">Equipo</a></li>
      <li><a href="#resenas" class="block py-1 hover:text-white">Reseñas</a></li>
      <li><a href="#contacto" class="block py-1 hover:text-white">Contacto</a></li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
