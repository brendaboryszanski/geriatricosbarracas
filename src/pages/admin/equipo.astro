---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

let successMsg = '';
let errorMsg = '';

async function uploadPhoto(file: File): Promise<string | null> {
  if (!file || file.size === 0) return null;
  const filename = `team/${Date.now()}-${file.name.replace(/\s/g, '-')}`;
  const { error } = await supabase.storage.from('images').upload(filename, file, { contentType: file.type });
  if (error) return null;
  const { data: { publicUrl } } = supabase.storage.from('images').getPublicUrl(filename);
  return publicUrl;
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action') as string;

  if (action === 'add') {
    const file = form.get('file') as File;
    const photo_url = await uploadPhoto(file);
    const { data: last } = await supabase.from('team').select('order').order('order', { ascending: false }).limit(1);
    const nextOrder = (last?.[0]?.order ?? 0) + 1;
    const { error } = await supabase.from('team').insert({
      name: form.get('name') as string,
      role: form.get('role') as string,
      bio: form.get('bio') as string,
      is_owner: form.get('is_owner') === 'on',
      photo_url: photo_url ?? '',
      order: nextOrder,
    });
    if (error) errorMsg = `Error al agregar: ${error.message}`;
    else successMsg = 'Miembro agregado.';

  } else if (action === 'update') {
    const id = form.get('id') as string;
    const file = form.get('file') as File;
    const photo_url = await uploadPhoto(file);
    const updateData: Record<string, unknown> = {
      name: form.get('name') as string,
      role: form.get('role') as string,
      bio: form.get('bio') as string,
      is_owner: form.get('is_owner') === 'on',
    };
    if (photo_url) updateData.photo_url = photo_url;
    const { error } = await supabase.from('team').update(updateData).eq('id', id);
    if (error) errorMsg = `Error al guardar: ${error.message}`;
    else successMsg = 'Guardado correctamente.';

  } else if (action === 'delete') {
    const id = form.get('id') as string;
    const { error } = await supabase.from('team').delete().eq('id', id);
    if (error) errorMsg = `Error al eliminar: ${error.message}`;
    else successMsg = 'Miembro eliminado.';

  } else if (action === 'reorder') {
    const ids = JSON.parse(form.get('ids') as string) as string[];
    const updates = ids.map((id, i) => supabase.from('team').update({ order: i + 1 }).eq('id', id));
    const results = await Promise.all(updates);
    if (results.some(r => r.error)) errorMsg = 'Error al guardar el orden.';
    else successMsg = 'Orden guardado.';
  }
}

const { data: members } = await supabase
  .from('team')
  .select('*')
  .order('is_owner', { ascending: false })
  .order('order');
---

<AdminLayout title="Equipo" activeSection="equipo">
  <h2 class="font-heading font-800 text-2xl text-sage mb-1">Equipo</h2>
  <p class="text-warm-gray text-sm mb-8">Podés agregar, editar o eliminar miembros. Arrastrá para reordenar.</p>

  {successMsg && <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-4 py-3 text-sm mb-6">{successMsg}</div>}
  {errorMsg && <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm mb-6">{errorMsg}</div>}

  <!-- Add new member -->
  <div class="bg-white rounded-2xl border border-warm-border p-6 mb-8">
    <h3 class="font-heading font-700 text-sage mb-4">Agregar miembro</h3>
    <form method="POST" enctype="multipart/form-data" class="flex flex-col gap-3">
      <input type="hidden" name="_action" value="add" />
      <div class="grid sm:grid-cols-2 gap-3">
        <div class="flex flex-col gap-1">
          <label class="text-sm font-medium text-warm-dark">Nombre</label>
          <input name="name" required placeholder="Nombre completo" class="border border-warm-border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-sage" />
        </div>
        <div class="flex flex-col gap-1">
          <label class="text-sm font-medium text-warm-dark">Rol / Especialidad</label>
          <input name="role" placeholder="Ej: Enfermera" class="border border-warm-border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-sage" />
        </div>
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-sm font-medium text-warm-dark">Descripción breve</label>
        <textarea name="bio" rows="2" class="border border-warm-border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-sage resize-none"></textarea>
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-sm font-medium text-warm-dark">Foto</label>
        <input type="file" name="file" accept="image/*" class="text-sm file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border-0 file:bg-sage/10 file:text-sage file:cursor-pointer" />
      </div>
      <div class="flex items-center gap-4">
        <label class="flex items-center gap-2 text-sm text-warm-dark cursor-pointer">
          <input type="checkbox" name="is_owner" class="rounded" />
          Es dueño/a de la residencia
        </label>
        <button type="submit" class="bg-sage hover:bg-sage-dark text-white px-5 py-2 rounded-xl text-sm font-medium transition-colors">
          Agregar
        </button>
      </div>
    </form>
  </div>

  <!-- Existing members — sortable -->
  {members && members.length > 0 && (
    <div>
      <div class="flex items-center justify-between mb-3">
        <h3 class="font-heading font-700 text-sage">Miembros actuales</h3>
        <p class="text-xs text-warm-gray">Arrastrá para reordenar</p>
      </div>

      <form method="POST" id="team-reorder-form">
        <input type="hidden" name="_action" value="reorder" />
        <input type="hidden" name="ids" id="team-reorder-ids" value={JSON.stringify(members.map(m => String(m.id)))} />

        <div id="team-sortable" class="flex flex-col gap-4 mb-4">
          {members.map((m) => (
            <div class="team-sortable-item bg-white rounded-2xl border border-warm-border p-4" data-id={m.id}>
              <div class="flex gap-4">
                <!-- Drag handle -->
                <div class="drag-handle shrink-0 flex items-center cursor-grab text-warm-border hover:text-warm-gray transition-colors select-none" title="Arrastrá para reordenar">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16"/>
                  </svg>
                </div>

                <!-- Photo -->
                <img src={m.photo_url} alt={m.name} class="w-16 h-16 rounded-full object-cover border-2 border-warm-border shrink-0" />

                <!-- Form -->
                <form method="POST" enctype="multipart/form-data" class="flex-1 min-w-0 flex flex-col gap-2">
                  <input type="hidden" name="_action" value="update" />
                  <input type="hidden" name="id" value={m.id} />
                  <input name="name" value={m.name} required placeholder="Nombre"
                    class="w-full border border-warm-border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-sage" />
                  <input name="role" value={m.role} placeholder="Rol"
                    class="w-full border border-warm-border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-sage" />
                  <textarea name="bio" rows="2" class="w-full border border-warm-border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-sage resize-none">{m.bio}</textarea>
                  <div class="flex flex-wrap items-center gap-3">
                    <label class="text-xs text-sage cursor-pointer hover:underline">
                      Cambiar foto
                      <input type="file" name="file" accept="image/*" class="hidden" />
                    </label>
                    <label class="flex items-center gap-1.5 text-xs text-warm-dark cursor-pointer">
                      <input type="checkbox" name="is_owner" checked={m.is_owner} class="rounded" />
                      Es dueño/a
                    </label>
                    <div class="flex gap-2 ml-auto">
                      <button type="submit" class="bg-sage hover:bg-sage-dark text-white px-3 py-1.5 rounded-xl text-xs font-medium transition-colors">
                        Guardar
                      </button>
                      <button type="submit" form={`del-m-${m.id}`} class="bg-red-50 hover:bg-red-100 text-red-600 px-3 py-1.5 rounded-xl text-xs font-medium transition-colors">
                        Eliminar
                      </button>
                    </div>
                  </div>
                </form>
                <form id={`del-m-${m.id}`} method="POST" class="hidden">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={m.id} />
                </form>
              </div>
            </div>
          ))}
        </div>

        <button type="submit" class="bg-warm-dark hover:bg-black text-white px-5 py-2 rounded-xl text-sm font-medium transition-colors">
          Guardar orden
        </button>
      </form>
    </div>
  )}
</AdminLayout>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1/Sortable.min.js" is:inline></script>
<script is:inline>
  const list = document.getElementById('team-sortable');
  const idsInput = document.getElementById('team-reorder-ids');
  if (list && idsInput) {
    new Sortable(list, {
      handle: '.drag-handle',
      animation: 150,
      onEnd() {
        const ids = [...list.querySelectorAll('[data-id]')].map(el => el.dataset.id);
        idsInput.value = JSON.stringify(ids);
      }
    });
  }
</script>
