---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

let successMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  // Update contact key-value fields
  const contactUpdates = [
    { key: 'email', value: form.get('email') as string },
    { key: 'map_url', value: form.get('map_url') as string },
    { key: 'footer_text', value: form.get('footer_text') as string },
  ];

  const contactErrors = await Promise.all(
    contactUpdates.map(({ key, value }) =>
      supabase.from('contact').update({ value }).eq('key', key)
    )
  );

  // Update phone numbers in residences table
  const residenceUpdates = [
    { id: form.get('lesa_id') as string, phone: form.get('lesa_phone') as string },
    { id: form.get('rincon_id') as string, phone: form.get('rincon_phone') as string },
  ];

  const residenceErrors = await Promise.all(
    residenceUpdates
      .filter(r => r.id)
      .map(({ id, phone }) =>
        supabase.from('residences').update({ phone }).eq('id', id)
      )
  );

  const hasError =
    contactErrors.some(r => r.error) ||
    residenceErrors.some(r => r.error);

  if (hasError) errorMsg = 'Error al guardar algunos campos.';
  else successMsg = 'Guardado correctamente.';
}

const { data: contactRows } = await supabase.from('contact').select('*');
const contact: Record<string, string> = {};
contactRows?.forEach(row => { contact[row.key] = row.value; });

const { data: residences } = await supabase
  .from('residences')
  .select('id, name, phone')
  .order('id');
---

<AdminLayout title="Contacto" activeSection="contacto">
  <h2 class="font-heading font-800 text-2xl text-sage mb-1">Contacto</h2>
  <p class="text-warm-gray text-sm mb-8">Editá los datos de contacto del sitio.</p>

  {successMsg && <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-4 py-3 text-sm mb-6">{successMsg}</div>}
  {errorMsg && <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm mb-6">{errorMsg}</div>}

  <form method="POST" class="flex flex-col gap-6">

    <!-- Phones -->
    <div class="bg-white rounded-2xl border border-warm-border p-6 flex flex-col gap-4">
      <h3 class="font-heading font-700 text-sage">Teléfonos</h3>
      {residences?.map(r => (
        <div class="flex flex-col gap-1">
          <input type="hidden" name={`${r.name === 'Le-Sa' ? 'lesa' : 'rincon'}_id`} value={r.id} />
          <label class="text-sm font-medium text-warm-dark">{r.name}</label>
          <input
            name={`${r.name === 'Le-Sa' ? 'lesa' : 'rincon'}_phone`}
            value={r.phone}
            placeholder="Ej: +54 9 11 3447-8263"
            class="border border-warm-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-sage focus:ring-1 focus:ring-sage"
          />
        </div>
      ))}
    </div>

    <!-- Email -->
    <div class="bg-white rounded-2xl border border-warm-border p-6 flex flex-col gap-4">
      <h3 class="font-heading font-700 text-sage">Email y otros datos</h3>

      <div class="flex flex-col gap-1">
        <label class="text-sm font-medium text-warm-dark">Email de contacto</label>
        <input name="email" type="email" value={contact.email}
          class="border border-warm-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-sage" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-sm font-medium text-warm-dark">URL del mapa de Google</label>
        <input name="map_url" value={contact.map_url}
          class="border border-warm-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-sage font-mono" />
        <p class="text-xs text-warm-gray">El src del iframe de Google Maps.</p>
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-sm font-medium text-warm-dark">Texto del pie de página</label>
        <input name="footer_text" value={contact.footer_text}
          class="border border-warm-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-sage" />
      </div>
    </div>

    <button type="submit" class="self-start bg-sage hover:bg-sage-dark text-white px-6 py-2.5 rounded-xl text-sm font-medium transition-colors">
      Guardar cambios
    </button>
  </form>
</AdminLayout>
