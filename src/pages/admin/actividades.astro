---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

let successMsg = '';
let errorMsg = '';

async function uploadImage(file: File, folder: string): Promise<string | null> {
  if (!file || file.size === 0) return null;
  const filename = `${folder}/${Date.now()}-${file.name.replace(/\s/g, '-')}`;
  const { error } = await supabase.storage.from('images').upload(filename, file, { contentType: file.type });
  if (error) return null;
  const { data: { publicUrl } } = supabase.storage.from('images').getPublicUrl(filename);
  return publicUrl;
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action') as string;

  if (action === 'add') {
    const file = form.get('file') as File;
    const image_url = await uploadImage(file, 'activities');
    const { data: last } = await supabase.from('activities').select('order').order('order', { ascending: false }).limit(1);
    const nextOrder = (last?.[0]?.order ?? 0) + 1;
    const { error } = await supabase.from('activities').insert({
      title: form.get('title') as string,
      description: form.get('description') as string,
      image_url: image_url ?? '',
      order: nextOrder,
    });
    if (error) errorMsg = `Error al agregar: ${error.message}`;
    else successMsg = 'Actividad agregada.';

  } else if (action === 'update') {
    const id = form.get('id') as string;
    const file = form.get('file') as File;
    const image_url = await uploadImage(file, 'activities');
    const updateData: Record<string, unknown> = {
      title: form.get('title') as string,
      description: form.get('description') as string,
    };
    if (image_url) updateData.image_url = image_url;
    const { error } = await supabase.from('activities').update(updateData).eq('id', id);
    if (error) errorMsg = `Error al guardar: ${error.message}`;
    else successMsg = 'Guardado correctamente.';

  } else if (action === 'delete') {
    const id = form.get('id') as string;
    const { error } = await supabase.from('activities').delete().eq('id', id);
    if (error) errorMsg = `Error al eliminar: ${error.message}`;
    else successMsg = 'Actividad eliminada.';

  } else if (action === 'reorder') {
    const ids = JSON.parse(form.get('ids') as string) as string[];
    const updates = ids.map((id, i) => supabase.from('activities').update({ order: i + 1 }).eq('id', id));
    const results = await Promise.all(updates);
    if (results.some(r => r.error)) errorMsg = 'Error al guardar el orden.';
    else successMsg = 'Orden guardado.';
  }
}

const { data: activities } = await supabase.from('activities').select('*').order('order');
---

<AdminLayout title="Actividades" activeSection="actividades">
  <h2 class="font-heading font-800 text-2xl text-sage mb-1">Actividades</h2>
  <p class="text-warm-gray text-sm mb-8">Podés agregar, editar o eliminar actividades. Arrastrá para reordenar.</p>

  {successMsg && <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-4 py-3 text-sm mb-6">{successMsg}</div>}
  {errorMsg && <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm mb-6">{errorMsg}</div>}

  <!-- Add new -->
  <div class="bg-white rounded-2xl border border-warm-border p-6 mb-8">
    <h3 class="font-heading font-700 text-sage mb-4">Agregar actividad</h3>
    <form method="POST" enctype="multipart/form-data" class="flex flex-col gap-3">
      <input type="hidden" name="_action" value="add" />
      <div class="flex flex-col gap-1">
        <label class="text-sm font-medium text-warm-dark">Título</label>
        <input name="title" required placeholder="Ej: Terapia ocupacional" class="border border-warm-border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-sage" />
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-sm font-medium text-warm-dark">Descripción</label>
        <textarea name="description" rows="2" required class="border border-warm-border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-sage resize-none"></textarea>
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-sm font-medium text-warm-dark">Imagen</label>
        <input type="file" name="file" accept="image/*" class="text-sm file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border-0 file:bg-sage/10 file:text-sage file:cursor-pointer" />
      </div>
      <div>
        <button type="submit" class="bg-sage hover:bg-sage-dark text-white px-5 py-2 rounded-xl text-sm font-medium transition-colors">
          Agregar
        </button>
      </div>
    </form>
  </div>

  <!-- Existing — sortable -->
  {activities && activities.length > 0 && (
    <div>
      <div class="flex items-center justify-between mb-3">
        <h3 class="font-heading font-700 text-sage">Actividades actuales</h3>
        <p class="text-xs text-warm-gray">Arrastrá para reordenar</p>
      </div>

      <form method="POST" id="activities-reorder-form">
        <input type="hidden" name="_action" value="reorder" />
        <input type="hidden" name="ids" id="activities-reorder-ids" value={JSON.stringify(activities.map(a => String(a.id)))} />

        <div id="activities-sortable" class="flex flex-col gap-4 mb-4">
          {activities.map((a) => (
            <div class="activities-sortable-item bg-white rounded-2xl border border-warm-border overflow-hidden" data-id={a.id}>
              <div class="flex items-start gap-3 p-4">
                <div class="drag-handle shrink-0 mt-1 cursor-grab text-warm-border hover:text-warm-gray transition-colors select-none">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16"/>
                  </svg>
                </div>
                <img src={a.image_url} alt={a.title} class="w-16 h-16 rounded-full object-cover border-2 border-warm-border shrink-0" />
                <form method="POST" enctype="multipart/form-data" class="flex-1 flex flex-col gap-2">
                  <input type="hidden" name="_action" value="update" />
                  <input type="hidden" name="id" value={a.id} />
                  <input name="title" value={a.title} class="border border-warm-border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-sage" />
                  <textarea name="description" rows="2" class="border border-warm-border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-sage resize-none">{a.description}</textarea>
                  <div class="flex flex-wrap items-center gap-3">
                    <label class="text-xs text-sage cursor-pointer hover:underline">
                      Cambiar imagen
                      <input type="file" name="file" accept="image/*" class="hidden" />
                    </label>
                    <div class="flex gap-2 ml-auto">
                      <button type="submit" class="bg-sage hover:bg-sage-dark text-white px-3 py-1.5 rounded-xl text-xs font-medium transition-colors">Guardar</button>
                      <button type="submit" form={`del-a-${a.id}`} class="bg-red-50 hover:bg-red-100 text-red-600 px-3 py-1.5 rounded-xl text-xs font-medium transition-colors">Eliminar</button>
                    </div>
                  </div>
                </form>
                <form id={`del-a-${a.id}`} method="POST" class="hidden">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={a.id} />
                </form>
              </div>
            </div>
          ))}
        </div>

        <button type="submit" class="bg-warm-dark hover:bg-black text-white px-5 py-2 rounded-xl text-sm font-medium transition-colors">
          Guardar orden
        </button>
      </form>
    </div>
  )}
</AdminLayout>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1/Sortable.min.js" is:inline></script>
<script is:inline>
  const list = document.getElementById('activities-sortable');
  const idsInput = document.getElementById('activities-reorder-ids');
  if (list && idsInput) {
    new Sortable(list, {
      handle: '.drag-handle',
      animation: 150,
      onEnd() {
        const ids = [...list.querySelectorAll('[data-id]')].map(el => el.dataset.id);
        idsInput.value = JSON.stringify(ids);
      }
    });
  }
</script>
