---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSlider from '../components/HeroSlider.astro';
import ResidenceCards from '../components/ResidenceCards.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import ActivitiesSection from '../components/ActivitiesSection.astro';
import GallerySection from '../components/GallerySection.astro';
import TeamSection from '../components/TeamSection.astro';
import ObjectivesSection from '../components/ObjectivesSection.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import FaqsSection from '../components/FaqsSection.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import FloatingButtons from '../components/FloatingButtons.astro';
import { supabase } from '../lib/supabase';
import { optimizeImage } from '../lib/utils';

const [
  { data: slides },
  { data: residences },
  { data: services },
  { data: activities },
  { data: photos },
  { data: members },
  { data: objectives },
  { data: contactRows },
  { data: faqs },
  { data: galleryCategories },
] = await Promise.all([
  supabase.from('slider').select('*').order('order'),
  supabase.from('residences').select('*').order('id'),
  supabase.from('services').select('*').order('order'),
  supabase.from('activities').select('*').order('order'),
  supabase.from('gallery').select('id, title, image_url, residence, subcategory').order('id'),
  supabase.from('team').select('*').order('is_owner', { ascending: false }).order('order'),
  supabase.from('objectives').select('*').order('id'),
  supabase.from('contact').select('*'),
  supabase.from('faqs').select('*').order('order'),
  supabase.from('gallery_subcategories').select('name').order('name'),
]);

const contactMap: Record<string, string> = {};
contactRows?.forEach(row => { contactMap[row.key] = row.value; });

const contact = {
  email: contactMap.email ?? '',
  map_url: contactMap.map_url ?? '',
  residences: residences?.map(r => ({ name: r.name, phone: r.phone, address: r.address })) ?? [],
};

const footerText = contactMap.footer_text ?? 'Residencias para adultos mayores';
const firstSlideImage = slides?.[0]?.image_url
  ? optimizeImage(slides[0].image_url, 1200, 80)
  : undefined;
---

<Layout ogImage={firstSlideImage}>
  <Navbar showFaqs={(faqs ?? []).length > 0} />
  <HeroSlider slides={slides ?? []} />
  <ResidenceCards residences={residences ?? []} />
  <ServicesGrid services={services ?? []} />
  <ActivitiesSection activities={activities ?? []} />
  <GallerySection photos={photos ?? []} subcategories={(galleryCategories ?? []).map(c => c.name)} />
  <TeamSection members={members ?? []} />
  <ObjectivesSection objectives={objectives ?? []} />
  <ReviewsSection />
  <FaqsSection faqs={faqs ?? []} />
  <ContactSection contact={contact} />
  <Footer text={footerText} />
  <FloatingButtons />
</Layout>
