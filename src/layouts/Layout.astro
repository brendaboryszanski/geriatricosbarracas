---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Geriátricos Barracas | Le-Sa y Rincón del Sur',
  description = 'Residencias para adultos mayores en Barracas, Capital Federal. Le-Sa y Rincón del Sur, atendidas por sus dueños con calidez y profesionalismo.',
  ogImage,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, 'https://geriatricosbarracas.com.ar').href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_AR" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    {ogImage && <link rel="preload" as="image" href={ogImage} fetchpriority="high" />}
    <title>{title}</title>
  </head>
  <body class="bg-cream text-warm-dark">
    <slot />
    <script is:inline>
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            observer.unobserve(e.target);
          }
        }),
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(el => observer.observe(el));
    </script>
    <script is:inline>
      // Fix: anchor scroll can land in the wrong spot because lazy-loaded images
      // above the target push content down after the initial scroll. We re-align
      // when pending images finish loading, unless the user has scrolled manually.
      (function () {
        let currentHash = '';
        let userScrolled = false;

        function targetEl() {
          if (!currentHash) return null;
          try { return document.querySelector(currentHash); } catch { return null; }
        }

        function realign(smooth) {
          const el = targetEl();
          if (!el || userScrolled) return;
          el.scrollIntoView({ behavior: smooth ? 'smooth' : 'auto', block: 'start' });
        }

        function watchPendingImages() {
          const imgs = Array.from(document.images).filter(img => !img.complete);
          imgs.forEach(img => {
            const onDone = () => {
              img.removeEventListener('load', onDone);
              img.removeEventListener('error', onDone);
              realign(false);
            };
            img.addEventListener('load', onDone);
            img.addEventListener('error', onDone);
          });
        }

        function engage(hash) {
          currentHash = hash;
          userScrolled = false;
          realign(true);
          watchPendingImages();
        }

        document.addEventListener('click', (e) => {
          const a = e.target.closest && e.target.closest('a[href^="#"]');
          if (!a) return;
          const href = a.getAttribute('href');
          if (!href || href === '#') return;
          const el = document.querySelector(href);
          if (!el) return;
          e.preventDefault();
          if (location.hash !== href) history.pushState(null, '', href);
          engage(href);
        });

        ['wheel', 'touchmove', 'keydown'].forEach(evt => {
          window.addEventListener(evt, () => { userScrolled = true; }, { passive: true });
        });

        window.addEventListener('load', () => {
          if (location.hash && location.hash.length > 1) {
            engage(location.hash);
          }
        });

        window.addEventListener('hashchange', () => {
          if (location.hash) engage(location.hash);
        });
      })();
    </script>
  </body>
</html>
